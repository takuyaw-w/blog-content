{
  "name": "blog-content",
  "version": "1.0.0",
  "description": "Content repository for an Astro blog template.",
  "private": true,
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "format": "oxfmt --write \"README.md\" \"{blog,projects,about}/**/*.{md,mdx}\"",
    "format:check": "oxfmt --check \"README.md\" \"{blog,projects,about}/**/*.{md,mdx}\"",
    "lint": "textlint \"{blog,projects,about}/**/*.{md,mdx}\"",
    "lint:fix": "textlint --fix \"{blog,projects,about}/**/*.{md,mdx}\"",
    "lint:blog": "textlint \"blog/**/*.{md,mdx}\"",
    "lint:projects": "textlint \"projects/**/*.{md,mdx}\"",
    "lint:about": "textlint \"about/**/*.{md,mdx}\"",
    "new:post": "node scripts/new-content.mjs post",
    "new:project": "node scripts/new-content.mjs project"
  },
  "devDependencies": {
    "oxfmt": "^0.55.0",
    "textlint": "^15.2.2",
    "textlint-filter-rule-allowlist": "^4.0.0",
    "textlint-filter-rule-comments": "^1.2.2",
    "textlint-rule-preset-ja-technical-writing": "^12.0.2",
    "textlint-rule-preset-japanese": "^10.0.4"
  }
}
